{"ast":null,"code":"import Footer from '@/components/Footer';\nexport default {\n  name: \"AboutUs\",\n  components: {\n    Footer\n  }\n};","map":{"version":3,"names":["Footer","name","components"],"sources":["src/pages/AboutUs/index.vue"],"sourcesContent":["<template>\n  <div class=\"about-page\">\n    <!-- Hero 区 -->\n    <section class=\"about-hero\">\n      <div class=\"page-container\">\n        <h1 class=\"about-hero-title\">关于云才科技</h1>\n        <p class=\"about-hero-desc\">\n          以技术驱动招聘革新，用智能算法赋能人才决策\n        </p>\n      </div>\n    </section>\n\n    <!-- 公司简介 -->\n    <section class=\"about-section\">\n      <div class=\"page-container\">\n        <div class=\"about-intro\">\n          <div class=\"about-intro-text\">\n            <h2 class=\"section-title\">公司简介</h2>\n            <p>云才科技成立于2023年，是一家专注于企业智能招聘管理领域的技术型公司。我们深度融合人工智能与人力资源管理，致力于为企业提供高效、客观、可解释的简历筛选解决方案。</p>\n            <p>公司核心产品——智能简历OA筛选系统，基于经典决策树算法（ID3/C4.5/CART），通过对简历关键特征进行信息增益计算，实现自动化简历分类与智能推荐，帮助HR将初筛时间缩短80%以上。</p>\n            <p>截至目前，云才科技已服务超过200家企业客户，覆盖互联网、金融、制造、医疗等多个行业，累计处理简历超过50万份。</p>\n          </div>\n          <div class=\"about-intro-img\">\n            <img src=\"https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80\" alt=\"公司团队合影图片\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 核心数据 -->\n    <section class=\"about-stats\">\n      <div class=\"page-container\">\n        <div class=\"stats-grid\">\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">200+</span>\n            <span class=\"stat-label\">服务企业</span>\n          </div>\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">50万+</span>\n            <span class=\"stat-label\">处理简历</span>\n          </div>\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">80%</span>\n            <span class=\"stat-label\">筛选效率提升</span>\n          </div>\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">98.5%</span>\n            <span class=\"stat-label\">匹配准确率</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 发展历程 -->\n    <section class=\"about-section\">\n      <div class=\"page-container\">\n        <h2 class=\"section-title\">发展历程</h2>\n        <p class=\"section-subtitle\">从构想到落地，每一步都扎实前行</p>\n        <div class=\"timeline\">\n          <div class=\"timeline-item\">\n            <div class=\"timeline-dot\"></div>\n            <div class=\"timeline-content\">\n              <h4>2025年11月</h4>\n              <p>项目立项，完成需求分析与技术调研</p>\n            </div>\n          </div>\n          <div class=\"timeline-item\">\n            <div class=\"timeline-dot\"></div>\n            <div class=\"timeline-content\">\n              <h4>2026年1月</h4>\n              <p>系统架构设计完成，前后端同步开发启动</p>\n            </div>\n          </div>\n          <div class=\"timeline-item\">\n            <div class=\"timeline-dot\"></div>\n            <div class=\"timeline-content\">\n              <h4>2026年3月</h4>\n              <p>核心决策树算法模块开发完成，模型训练通过验证</p>\n            </div>\n          </div>\n          <div class=\"timeline-item\">\n            <div class=\"timeline-dot\"></div>\n            <div class=\"timeline-content\">\n              <h4>2026年5月</h4>\n              <p>系统集成测试完成，正式上线运行</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <Footer></Footer>\n  </div>\n</template>\n\n<script>\nimport Footer from '@/components/Footer'\nexport default {\n  name: \"AboutUs\",\n  components: {\n    Footer\n  }\n}\n</script>\n\n<style scoped>\n.about-hero {\n  background: linear-gradient(135deg, #0f2640 0%, #1a3a5c 50%, #2c5282 100%);\n  padding: 80px 0 60px;\n  text-align: center;\n}\n\n.about-hero-title {\n  font-size: 36px;\n  font-weight: 700;\n  color: #fff;\n  margin: 0 0 12px;\n}\n\n.about-hero-desc {\n  font-size: 18px;\n  color: #94a3b8;\n  margin: 0;\n}\n\n.about-section {\n  padding: 60px 0;\n  background: #fff;\n}\n\n.about-intro {\n  display: flex;\n  align-items: center;\n  gap: 48px;\n}\n\n.about-intro-text {\n  flex: 1;\n}\n\n.about-intro-text .section-title {\n  text-align: left;\n}\n\n.about-intro-text p {\n  font-size: 16px;\n  line-height: 1.8;\n  color: var(--text-secondary);\n  margin: 16px 0;\n}\n\n.about-intro-img {\n  flex: 1;\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n  box-shadow: var(--shadow-md);\n}\n\n.about-intro-img img {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n\n.about-stats {\n  padding: 48px 0;\n  background: var(--bg-light);\n}\n\n.stats-grid {\n  display: flex;\n  justify-content: space-around;\n  flex-wrap: wrap;\n  gap: 24px;\n}\n\n.stat-item {\n  text-align: center;\n  padding: 24px;\n}\n\n.stat-number {\n  display: block;\n  font-size: 32px;\n  font-weight: 700;\n  color: var(--primary);\n  margin-bottom: 8px;\n}\n\n.stat-label {\n  font-size: 16px;\n  color: var(--text-secondary);\n}\n\n.timeline {\n  max-width: 600px;\n  margin: 0 auto;\n  position: relative;\n  padding-left: 30px;\n}\n\n.timeline::before {\n  content: '';\n  position: absolute;\n  left: 8px;\n  top: 0;\n  bottom: 0;\n  width: 2px;\n  background: var(--border-light);\n}\n\n.timeline-item {\n  position: relative;\n  padding-bottom: 32px;\n}\n\n.timeline-dot {\n  position: absolute;\n  left: -26px;\n  top: 4px;\n  width: 14px;\n  height: 14px;\n  border-radius: 50%;\n  background: var(--primary);\n  border: 3px solid #fff;\n  box-shadow: 0 0 0 2px var(--primary);\n}\n\n.timeline-content h4 {\n  font-size: 18px;\n  font-weight: 600;\n  color: var(--text-primary);\n  margin: 0 0 4px;\n}\n\n.timeline-content p {\n  font-size: 15px;\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n@media (max-width: 768px) {\n  .about-hero {\n    padding: 60px 0 40px;\n  }\n  .about-hero-title {\n    font-size: 28px;\n  }\n  .about-hero-desc {\n    font-size: 16px;\n  }\n  .about-intro {\n    flex-direction: column;\n    gap: 24px;\n  }\n  .about-intro-text .section-title {\n    text-align: center;\n  }\n  .stat-number {\n    font-size: 26px;\n  }\n}\n</style>\n"],"mappings":"AAgGA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}