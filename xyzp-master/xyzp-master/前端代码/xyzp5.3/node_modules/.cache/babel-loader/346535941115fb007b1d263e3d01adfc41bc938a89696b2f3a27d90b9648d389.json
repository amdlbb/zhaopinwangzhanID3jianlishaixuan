{"ast":null,"code":"export default {\n  name: 'TeamInfo',\n  data() {\n    return {\n      teamInfo: {},\n      isMySelf: false,\n      changPasswordDialogVisible: false,\n      myYuanPassword: \"\",\n      myNowPassword1: \"\",\n      myNowPassword2: \"\"\n    };\n  },\n  mounted() {\n    // 总线接收\n    this.$bus.$on(\"getTeamInfo\", () => {\n      this.init();\n    });\n  },\n  methods: {\n    // 点击上传图片事件\n    editAvatar() {\n      this.$refs[\"userAvatar\"].$refs[\"upload-inner\"].handleClick();\n    },\n    // 判断用户是否为本人\n    init() {\n      var pathId = this.$route.params.id;\n      var userInfo = this.$store.state.nav.userInfo;\n      if (pathId != userInfo.id) {\n        this.getTeamInfo(pathId);\n        this.isMySelf = false;\n      } else {\n        this.isMySelf = true;\n        this.getTeamInfo2(1);\n      }\n    },\n    // 获取团队信息，非本人\n    async getTeamInfo(id) {\n      let res = await this.$store.dispatch(\"getTeamInfo2\", {\n        id: id\n      });\n      if (res.code != 200) {\n        this.$message({\n          message: res.msg,\n          type: 'error',\n          center: true,\n          duration: 1500\n        });\n      } else {\n        this.userInfo = res.data;\n      }\n    },\n    async getTeamInfo2(id) {\n      let res = await this.$store.dispatch(\"getUserInfo\", {\n        id: id\n      });\n      if (res.code != 200) {\n        this.$message({\n          message: res.msg,\n          type: 'error',\n          center: true,\n          duration: 1500\n        });\n      } else {\n        this.teamInfo = res.data;\n      }\n    },\n    // 修改团队资料\n    async submitSave() {\n      if (!this.teamInfo.email || !this.teamInfo.nickname || !this.teamInfo.introduce || !this.teamInfo.address) {\n        this.$message({\n          message: '请正确填写',\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n        return;\n      }\n      // 发送请求\n      let res = await this.$store.dispatch(\"saveTeamInfo\", this.teamInfo);\n      if (res.code == 200) {\n        this.$message({\n          message: '更新成功',\n          type: 'success',\n          center: true,\n          duration: 1500\n        });\n        // 重新请求团队信息\n        res = await this.$store.dispatch(\"getUserInfo\", 1);\n        if (res.code != 200) {\n          this.$message({\n            message: res.msg,\n            type: 'error',\n            center: true,\n            duration: 1500\n          });\n        }\n      } else {\n        this.$message({\n          message: res.msg,\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n      }\n    },\n    // 超出限制\n    handleExceed(files, fileList) {\n      this.$message({\n        message: '只能选择一张图片',\n        type: 'warning',\n        center: true,\n        duration: 1500\n      });\n    },\n    // 上传成功\n    async uploadImage(param) {\n      const formData = new FormData();\n      formData.append('images', param.file);\n      formData.append('flag', 0);\n      let res = await this.$store.dispatch(\"getUpload\", formData);\n      if (res.code == 200) {\n        this.$message({\n          message: '修改头像成功',\n          type: 'success',\n          center: true,\n          duration: 1500\n        });\n        // 调用全局总线改变用户信息\n        this.$bus.$emit(\"getUserInfo\");\n        setTimeout(() => {\n          // 重新渲染信息\n          this.init();\n        }, 500);\n      } else {\n        this.$message({\n          message: res.msg,\n          type: 'error',\n          center: true,\n          duration: 1500\n        });\n      }\n      this.avatar = res.data;\n    },\n    // 修改密码\n    async submitChangPassword() {\n      if (this.myNowPassword1.trim() != this.myNowPassword2.trim()) {\n        this.$message({\n          message: '两次输入的密码不一致',\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n        return;\n      } else if (this.myNowPassword1.length < 8) {\n        this.$message({\n          message: '密码长度不少于8位',\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n        return;\n      } else if (this.myNowPassword1 == this.myYuanPassword) {\n        this.$message({\n          message: '新旧密码未发生改变',\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n        return;\n      }\n      // 发送请求\n      let res = await this.$store.dispatch(\"getChangTeamPassword\", {\n        beforePassword: this.$md5(this.myYuanPassword),\n        nowPassword: this.$md5(this.myNowPassword1)\n      });\n      if (res.code == 200) {\n        this.$message({\n          message: '修改密码成功',\n          type: 'warning',\n          center: true,\n          duration: 1500\n        });\n      } else {\n        this.$message({\n          message: res.msg,\n          type: 'error',\n          center: true,\n          duration: 1500\n        });\n      }\n    }\n  },\n  beforeDestroy() {\n    // 撤销总线\n    this.$bus.$off(\"getTeamInfo\");\n  }\n};","map":{"version":3,"names":["name","data","teamInfo","isMySelf","changPasswordDialogVisible","myYuanPassword","myNowPassword1","myNowPassword2","mounted","$bus","$on","init","methods","editAvatar","$refs","handleClick","pathId","$route","params","id","userInfo","$store","state","nav","getTeamInfo","getTeamInfo2","res","dispatch","code","$message","message","msg","type","center","duration","submitSave","email","nickname","introduce","address","handleExceed","files","fileList","uploadImage","param","formData","FormData","append","file","$emit","setTimeout","avatar","submitChangPassword","trim","length","beforePassword","$md5","nowPassword","beforeDestroy","$off"],"sources":["src/pages/TeamHome/TeamInfo/index.vue"],"sourcesContent":["<template>\n    <div class=\"teamDiv\">\n        <div class=\"teamDivTitle\">\n            <span>部门信息</span>\n        </div>\n        <div class=\"teamDivImg\">\n            <vue-hover-mask>\n                <el-upload :http-request=\"uploadImage\" action=\"\" :show-file-list=\"false\" :limit=\"1\"\n                    :on-exceed=\"handleExceed\" ref=\"userAvatar\">\n                    <img :src=\"teamInfo.avatar\" alt=\"点击修改图片\">\n                </el-upload>\n                <template v-slot:action>\n                    <span slot=\"default\" @click=\"editAvatar\">编辑</span>\n                </template>\n            </vue-hover-mask>\n\n        </div>\n        <div class=\"teamDivContentLine\">\n            <div class=\"teamDivContentItem\">\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-zhanghaoquanxianguanli\">账号</span>\n                </div>\n                <div>\n                    <input type=\"text\" v-model=\"teamInfo.username\" disabled>\n                </div>\n            </div>\n            <div class=\"teamDivContentItem\">\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-nicheng\">部门名称</span>\n                </div>\n                <div>\n                    <input type=\"text\" v-model=\"teamInfo.nickname\">\n                </div>\n            </div>\n        </div>\n        <div class=\"teamDivContentLine\">\n            <div class=\"teamDivContentItem\">\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-youxiang\">邮箱（用于接收招聘信息）</span>\n                </div>\n                <div>\n                    <input type=\"text\" v-model=\"teamInfo.email\" disabled>\n                </div>\n            </div>\n            <div class=\"teamDivContentItem\" v-show=\"isMySelf\">\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-mima\">密码</span>\n                </div>\n                <div>\n                    <button @click=\"changPasswordDialogVisible = true\">点击修改密码</button>\n                </div>\n            </div>\n        </div>\n        <div class=\"teamDivContentLine\">\n            <div class=\"teamDivContentItem\">\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-dizhi\">部门地址</span>\n                </div>\n                <div>\n                    <input type=\"text\" v-model=\"teamInfo.address\">\n                </div>\n            </div>\n        </div>\n        <div class=\"teamDivContentLineIntroduce\">\n            <div>\n                <div class=\"teamDivContentItemLabel\">\n                    <span class=\"iconfont icon-renyuanjieshao\">部门介绍</span>\n                </div>\n                <div>\n                    <el-input type=\"textarea\" autosize placeholder=\"不超过50个字\" v-model=\"teamInfo.introduce\">\n                    </el-input>\n                </div>\n            </div>\n        </div>\n        <div class=\"teamDivSave\">\n            <button @click=\"submitSave\" v-show=\"isMySelf\">保存</button>\n        </div>\n        <el-dialog title=\"修改密码\" :visible.sync=\"changPasswordDialogVisible\" width=\"30%\" center custom-class=\"dialogDiv\">\n            <div class=\"teamDivChangePasswordItem\">\n                <input type=\"password\" placeholder=\"请输入原密码\" v-model=\"myYuanPassword\">\n            </div>\n            <div class=\"teamDivChangePasswordItem\">\n                <input type=\"password\" placeholder=\"请输入修改后的密码\" v-model=\"myNowPassword1\">\n            </div>\n            <div class=\"teamDivChangePasswordItem\">\n                <input type=\"password\" placeholder=\"请再次输入修改后的密码\" v-model=\"myNowPassword2\">\n            </div>\n            <div class=\"teamDivChangePasswordItemBtn\">\n                <button @click=\"submitChangPassword\">修改</button>\n            </div>\n        </el-dialog>\n\n\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'TeamInfo',\n    data() {\n        return {\n            teamInfo: {},\n            isMySelf: false,\n            changPasswordDialogVisible: false,\n            myYuanPassword: \"\",\n            myNowPassword1: \"\",\n            myNowPassword2: \"\",\n        }\n    },\n    mounted() {\n        // 总线接收\n        this.$bus.$on(\"getTeamInfo\", () => {\n            this.init()\n        })\n    },\n    methods: {\n        // 点击上传图片事件\n        editAvatar() {\n            this.$refs[\"userAvatar\"].$refs[\"upload-inner\"].handleClick();\n        },\n        // 判断用户是否为本人\n        init() {\n            var pathId = this.$route.params.id\n            var userInfo = this.$store.state.nav.userInfo\n            if (pathId != userInfo.id) {\n                this.getTeamInfo(pathId)\n                this.isMySelf = false\n            }\n            else {\n                this.isMySelf = true\n                this.getTeamInfo2(1)\n            }\n        },\n        // 获取团队信息，非本人\n        async getTeamInfo(id) {\n            let res = await this.$store.dispatch(\"getTeamInfo2\", {\n                id: id\n            })\n            if (res.code != 200) {\n                this.$message({\n                    message: res.msg,\n                    type: 'error',\n                    center: true,\n                    duration: 1500\n                })\n            }\n            else {\n                this.userInfo = res.data\n            }\n        },\n        async getTeamInfo2(id) {\n            let res = await this.$store.dispatch(\"getUserInfo\", {\n                id: id\n            })\n            if (res.code != 200) {\n                this.$message({\n                    message: res.msg,\n                    type: 'error',\n                    center: true,\n                    duration: 1500\n                })\n            }\n            else {\n                this.teamInfo = res.data\n            }\n        },\n\n\n        // 修改团队资料\n        async submitSave() {\n            if (!this.teamInfo.email || !this.teamInfo.nickname || !this.teamInfo.introduce || !this.teamInfo.address) {\n                this.$message({\n                    message: '请正确填写',\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n                return\n            }\n            // 发送请求\n            let res = await this.$store.dispatch(\"saveTeamInfo\", this.teamInfo)\n            if (res.code == 200) {\n                this.$message({\n                    message: '更新成功',\n                    type: 'success',\n                    center: true,\n                    duration: 1500\n                })\n                // 重新请求团队信息\n                res = await this.$store.dispatch(\"getUserInfo\", 1)\n                if (res.code != 200) {\n                    this.$message({\n                        message: res.msg,\n                        type: 'error',\n                        center: true,\n                        duration: 1500\n                    })\n                }\n            }\n            else {\n                this.$message({\n                    message: res.msg,\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n            }\n\n        },\n        // 超出限制\n        handleExceed(files, fileList) {\n            this.$message({\n                message: '只能选择一张图片',\n                type: 'warning',\n                center: true,\n                duration: 1500\n            })\n        },\n        // 上传成功\n        async uploadImage(param) {\n            const formData = new FormData()\n            formData.append('images', param.file)\n            formData.append('flag', 0)\n            let res = await this.$store.dispatch(\"getUpload\", formData);\n            if (res.code == 200) {\n                this.$message({\n                    message: '修改头像成功',\n                    type: 'success',\n                    center: true,\n                    duration: 1500\n                })\n                // 调用全局总线改变用户信息\n                this.$bus.$emit(\"getUserInfo\")\n                setTimeout(() => {\n                    // 重新渲染信息\n                    this.init()\n                }, 500)\n            }\n            else {\n                this.$message({\n                    message: res.msg,\n                    type: 'error',\n                    center: true,\n                    duration: 1500\n                })\n            }\n            this.avatar = res.data\n        },\n        // 修改密码\n        async submitChangPassword() {\n            if (this.myNowPassword1.trim() != this.myNowPassword2.trim()) {\n                this.$message({\n                    message: '两次输入的密码不一致',\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n                return\n            }\n            else if (this.myNowPassword1.length < 8) {\n                this.$message({\n                    message: '密码长度不少于8位',\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n                return\n            }\n            else if (this.myNowPassword1 == this.myYuanPassword) {\n                this.$message({\n                    message: '新旧密码未发生改变',\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n                return\n            }\n            // 发送请求\n            let res = await this.$store.dispatch(\"getChangTeamPassword\", {\n                beforePassword: this.$md5(this.myYuanPassword),\n                nowPassword: this.$md5(this.myNowPassword1)\n            })\n            if (res.code == 200) {\n                this.$message({\n                    message: '修改密码成功',\n                    type: 'warning',\n                    center: true,\n                    duration: 1500\n                })\n            }\n            else {\n                this.$message({\n                    message: res.msg,\n                    type: 'error',\n                    center: true,\n                    duration: 1500\n                })\n            }\n        }\n    },\n    beforeDestroy() {\n        // 撤销总线\n        this.$bus.$off(\"getTeamInfo\")\n    }\n}\n</script>\n\n<style>\n.teamDivTitle {\n    font-size: 1.2rem;\n    height: 40px;\n    color: rgb(69, 67, 67);\n    border-bottom: 0.1px solid rgb(223, 219, 219);\n}\n\n.teamDivImg {\n    height: 150px;\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.teamDivImg img {\n    height: 100px;\n    border-radius: 50%;\n    cursor: pointer;\n}\n\n.teamDivImg .vue-hover-mask_action {\n    border-radius: 50%;\n}\n\n.teamDivContentLine {\n    display: flex;\n    align-items: center;\n    height: 70px;\n}\n\n.teamDivContentItem button {\n    padding: 5px;\n    font-size: 0.9rem;\n    border-radius: 3px;\n    background: #e06c73;\n    color: white;\n    border: 0;\n    width: 67%;\n    text-align: center;\n    cursor: pointer;\n}\n\n.teamDivContentItem button:active {\n    background: rgb(204, 28, 28);\n}\n\n.teamDivContentLineIntroduce {\n    width: 100%;\n    margin-top: 7px;\n}\n\n.teamDivContentLineIntroduce div {\n    width: 100%;\n}\n\n.teamDivContentLineIntroduce textarea {\n    padding: 5px 10px;\n    border: 1px solid #b8b8b8;\n    font-size: 1rem;\n    color: #1f1f1f;\n    font-family: PingFangSC-Regular, Tahoma, Helvetica, \"Microsoft Yahei\", \"微软雅黑\", Arial, STHeiti;\n}\n\n.teamDivContentLineIntroduce textarea:focus {\n    border: 2px solid black;\n    overflow-y: hidden;\n}\n\n.teamDivContentItem {\n    width: 50%;\n}\n\n.teamDivContentItem input {\n    padding: 5px 10px;\n    width: 60%;\n    border: 1px solid #b8b8b8;\n    font-size: 1rem;\n    color: #1f1f1f;\n    transition: .3s;\n    font-family: PingFangSC-Regular, Tahoma, Helvetica, \"Microsoft Yahei\", \"微软雅黑\", Arial, STHeiti;\n}\n\n.teamDivContentItem textarea {\n    padding: 5px 10px;\n    width: 60%;\n    border: 1px solid #b8b8b8;\n    font-size: 1rem;\n    color: #1f1f1f;\n    transition: .3s;\n    font-family: PingFangSC-Regular, Tahoma, Helvetica, \"Microsoft Yahei\", \"微软雅黑\", Arial, STHeiti;\n}\n\n.teamDivContentItemLabel {\n    border-left: 4px solid rgb(189, 189, 251);\n    padding-left: 5px;\n    font-size: 1rem;\n    color: rgb(112, 80, 121);\n    margin-bottom: 2px;\n}\n\n.teamDivSave {\n    text-align: center;\n    height: 50px;\n    margin: 10px 0 10px 0;\n}\n\n.teamDivSave button {\n    padding: 5px;\n    height: 30px;\n    font-size: 0.9rem;\n    background: #968ced;\n    color: white;\n    border: 0;\n    width: 20%;\n    border-radius: 3px;\n    text-align: center;\n    cursor: pointer;\n}\n\n.teamDivSave button:active {\n    background: rgb(88, 88, 241);\n}\n\n.teamDivChangePasswordItem {\n    height: 50px;\n    line-height: 50px;\n    text-align: center;\n}\n\n.teamDivChangePasswordItem input {\n    padding: 5px 10px;\n    width: 60%;\n    border: 1px solid #b8b8b8;\n    font-size: 1rem;\n    color: #1f1f1f;\n    transition: .3s;\n    font-family: PingFangSC-Regular, Tahoma, Helvetica, \"Microsoft Yahei\", \"微软雅黑\", Arial, STHeiti;\n}\n\n.teamDivChangePasswordItemBtn {\n    text-align: center;\n}\n\n.teamDivChangePasswordItemBtn button {\n    padding: 5px;\n    height: 30px;\n    font-size: 0.9rem;\n    border-radius: 3px;\n    background: #a6a0d9;\n    color: white;\n    border: 0;\n    width: 20%;\n    text-align: center;\n    cursor: pointer;\n}\n\n.teamDivChangePasswordItemBtn button:active {\n    background: rgb(145, 145, 234);\n}\n\n\n@media screen and (min-width: 1200px) {\n    .dialogDiv {\n        width: 30% !important;\n    }\n}\n\n@media screen and (max-width: 1200px) {\n    .dialogDiv {\n        width: 95% !important;\n    }\n}\n</style>"],"mappings":"AAiGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;MACAC,QAAA;MACAC,0BAAA;MACAC,cAAA;MACAC,cAAA;MACAC,cAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAAC,IAAA,CAAAC,GAAA;MACA,KAAAC,IAAA;IACA;EACA