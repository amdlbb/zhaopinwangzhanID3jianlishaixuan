) this.$bus.$emit(\"getInterviewInfo\")\n            else if(idx == 5) this.$bus.$emit(\"getTeamUserAdmission\")\n        }\n    },\n}\n</script>\n\n<style>\n.teamHomeDivMainItemA {\n    height: 50px;\n    line-height: 50px;\n    text-align: center;\n    cursor: pointer;\n    background-color: rgb(248, 246, 246);\n    color: #61687c;\n}\n\n.teamHomeDivMainItemB {\n    height: 50px;\n    line-height: 50px;\n    text-align: center;\n    cursor: pointer;\n    background-color: white;\n    color: #61687c;\n}\n\n.teamHomeDivMainItemC {\n    height: 50px;\n    line-height: 50px;\n    text-align: center;\n    cursor: pointer;\n    background-color: white;\n    color: #61687c;\n}\n\n\n.teamHomeDivMainItem2MyJianli {\n    width: 90%;\n    margin: auto;\n    padding-top: 20px;\n}\n\n.teamHomeDivMainItem2MyJob {\n    width: 90%;\n    margin: auto;\n    padding-top: 20px;\n}\n\n.teamHomeDivMainItem2MyInfo {\n    width: 90%;\n    margin: auto;\n    padding-top: 20px;\n}\n\n@media screen and (min-width: 1200px) {\n\n    .teamHomeDivMain {\n        width: 90%;\n        margin: auto;\n        margin-top: 20px;\n        display: flex;\n        align-items: flex-start;\n    }\n\n    .teamHomeDivMainItem1 {\n        width: 19%;\n        background-color: white;\n        font-size: 1rem;\n        margin-right: 1%;\n        box-shadow: 0 6px 9px rgba(50, 50, 93, .1), 0 5px 7px rgb(0 0 0/7%);\n    }\n\n    .teamHomeDivMainItem2 {\n        width: 80%;\n        background-color: white;\n        box-shadow: 0 6px 9px rgba(50, 50, 93, .1), 0 5px 7px rgb(0 0 0/7%);\n    }\n}\n\n@media screen and (min-width: 1200px) {\n    .teamHomeDivMain {\n        width: 90%;\n        margin: auto;\n        margin-top: 20px;\n        display: flex;\n        align-items: flex-start;\n    }\n\n    .teamHomeDivMainItem1 {\n        width: 19%;\n        background-color: white;\n        font-size: 1rem;\n        margin-right: 1%;\n        box-shadow: 0 6px 9px rgba(50, 50, 93, .1), 0 5px 7px rgb(0 0 0/7%);\n    