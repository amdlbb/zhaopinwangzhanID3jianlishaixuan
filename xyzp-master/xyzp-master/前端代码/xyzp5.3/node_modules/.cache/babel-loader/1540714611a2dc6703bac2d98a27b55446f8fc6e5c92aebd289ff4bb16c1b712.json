{"ast":null,"code":"export default {\n  name: \"Info\"\n};","map":{"version":3,"names":["name"],"sources":["src/pages/Home/Info/index.vue"],"sourcesContent":["<template>\n    <div class=\"infoDiv\">\n        <!-- 公司简介快览 -->\n        <section class=\"home-section home-intro\">\n            <div class=\"page-container\">\n                <h2 class=\"section-title\">智能招聘，从云才开始</h2>\n                <p class=\"section-subtitle\">专注企业智能招聘管理，用算法让人才匹配更精准</p>\n                <div class=\"intro-cards\">\n                    <div class=\"intro-card card\">\n                        <div class=\"intro-card-icon\">\n                            <img src=\"https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=80&q=80\" alt=\"智能筛选图标图片\">\n                        </div>\n                        <h3>智能简历筛选</h3>\n                        <p>基于ID3决策树算法，自动判定简历匹配度</p>\n                    </div>\n                    <div class=\"intro-card card\">\n                        <div class=\"intro-card-icon\">\n                            <img src=\"https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=80&q=80\" alt=\"流程管理图标图片\">\n                        </div>\n                        <h3>招聘流程管理</h3>\n                        <p>覆盖发布、筛选、面试、录取全流程</p>\n                    </div>\n                    <div class=\"intro-card card\">\n                        <div class=\"intro-card-icon\">\n                            <img src=\"https://images.unsplash.com/photo-1520607162513-77705c0f0dbf?w=80&q=80\" alt=\"数据分析图标图片\">\n                        </div>\n                        <h3>数据统计分析</h3>\n                        <p>多维数据看板，驱动招聘决策优化</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 核心数据 -->\n        <section class=\"home-section home-stats\">\n            <div class=\"page-container\">\n                <div class=\"stats-row\">\n                    <div class=\"stats-row-item\">\n                        <span class=\"stats-row-num\">200+</span>\n                        <span class=\"stats-row-label\">合作企业</span>\n                    </div>\n                    <div class=\"stats-row-item\">\n                        <span class=\"stats-row-num\">50万+</span>\n                        <span class=\"stats-row-label\">处理简历</span>\n                    </div>\n                    <div class=\"stats-row-item\">\n                        <span class=\"stats-row-num\">80%</span>\n                        <span class=\"stats-row-label\">效率提升</span>\n                    </div>\n                    <div class=\"stats-row-item\">\n                        <span class=\"stats-row-num\">98%</span>\n                        <span class=\"stats-row-label\">匹配准确率</span>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- 热门职位 -->\n        <section class=\"home-section home-jobs\">\n            <div class=\"page-container\">\n                <h2 class=\"section-title\">热门招聘职位</h2>\n                <p class=\"section-subtitle\">各行业优质岗位，等你来投递</p>\n                <div class=\"job-cards\">\n                    <div class=\"job-card card\" v-for=\"index in 6\" :key=\"index\">\n                        <div class=\"job-card-top\">\n                            <div class=\"job-card-avatar\">\n                                <img src=\"https://image0.lietou-static.com/bg_white_222x222/5bfe919474719d35745adb7903a.png\" alt=\"企业logo图片\">\n                            </div>\n                            <div class=\"job-card-info\">\n                                <h4>高级前端工程师</h4>\n                                <span class=\"job-card-company\">科技公司</span>\n                            </div>\n                        </div>\n                        <div class=\"job-card-tags\">\n                            <span class=\"job-tag\">15k-25k</span>\n                            <span class=\"job-tag\">本科</span>\n                            <span class=\"job-tag\">3-5年</span>\n                        </div>\n                        <div class=\"job-card-bottom\">\n                            <span class=\"job-card-location\">北京 · 海淀</span>\n                            <span class=\"job-card-status\">正在热招</span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"home-jobs-more\">\n                    <a href=\"/workhome\" class=\"btn-outline\">查看全部职位 →</a>\n                </div>\n            </div>\n        </section>\n\n        <!-- 新闻动态预览 -->\n        <section class=\"home-section home-news\">\n            <div class=\"page-container\">\n                <h2 class=\"section-title\">新闻动态</h2>\n                <p class=\"section-subtitle\">了解云才科技最新资讯</p>\n                <div class=\"news-pre-list\">\n                    <div class=\"news-pre-item\" v-for=\"index in 3\" :key=\"index\">\n                        <div class=\"news-pre-img\">\n                            <img src=\"https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=400&q=80\" alt=\"新闻配图\">\n                        </div>\n                        <div class=\"news-pre-content\">\n                            <span class=\"news-pre-date\">2026-04-28</span>\n                            <h4 class=\"news-pre-title\">云才科技智能简历筛选系统正式上线运行</h4>\n                            <p class=\"news-pre-desc\">经过数月的研发与测试，云才科技智能简历OA筛选系统正式上线...</p>\n                            <a href=\"/news\" class=\"news-pre-link\">阅读更多 →</a>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"home-news-more\">\n                    <a href=\"/news\" class=\"btn-outline\">查看更多动态 →</a>\n                </div>\n            </div>\n        </section>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: \"Info\"\n}\n</script>\n\n<style scoped>\n.home-section {\n    padding: 60px 0;\n}\n\n.home-intro {\n    background: #fff;\n}\n\n/* 介绍卡片 */\n.intro-cards {\n    display: flex;\n    gap: 24px;\n    justify-content: center;\n}\n\n.intro-card {\n    flex: 1;\n    max-width: 320px;\n    padding: 32px 24px;\n    text-align: center;\n    border: 1px solid var(--border-light);\n}\n\n.intro-card-icon {\n    width: 64px;\n    height: 64px;\n    margin: 0 auto 16px;\n    border-radius: 12px;\n    overflow: hidden;\n}\n\n.intro-card-icon img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n}\n\n.intro-card h3 {\n    font-size: 17px;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin: 0 0 8px;\n}\n\n.intro-card p {\n    font-size: 14px;\n    color: var(--text-secondary);\n    margin: 0;\n    line-height: 1.6;\n}\n\n/* 数据统计 */\n.home-stats {\n    background: var(--primary);\n    padding: 48px 0;\n}\n\n.stats-row {\n    display: flex;\n    justify-content: space-around;\n    flex-wrap: wrap;\n    gap: 20px;\n}\n\n.stats-row-item {\n    text-align: center;\n    color: #fff;\n}\n\n.stats-row-num {\n    display: block;\n    font-size: 36px;\n    font-weight: 700;\n    margin-bottom: 6px;\n}\n\n.stats-row-label {\n    font-size: 16px;\n    color: #94a3b8;\n}\n\n/* 热门职位 */\n.home-jobs {\n    background: var(--bg-body);\n}\n\n.job-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n    gap: 20px;\n    margin-bottom: 32px;\n}\n\n.job-card {\n    padding: 20px;\n    border: 1px solid var(--border-light);\n    cursor: pointer;\n    transition: all 0.2s;\n}\n\n.job-card:hover {\n    border-color: var(--primary-light);\n}\n\n.job-card-top {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 12px;\n}\n\n.job-card-avatar {\n    width: 48px;\n    height: 48px;\n    border-radius: 50%;\n    overflow: hidden;\n    flex-shrink: 0;\n    background: var(--bg-light);\n}\n\n.job-card-avatar img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n}\n\n.job-card-info h4 {\n    font-size: 16px;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin: 0 0 4px;\n}\n\n.job-card-company {\n    font-size: 13px;\n    color: var(--text-muted);\n}\n\n.job-card-tags {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-bottom: 12px;\n}\n\n.job-tag {\n    font-size: 12px;\n    padding: 3px 10px;\n    background: var(--bg-light);\n    color: var(--primary-light);\n    border-radius: 4px;\n    font-weight: 500;\n}\n\n.job-card-bottom {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding-top: 12px;\n    border-top: 1px solid var(--border-light);\n}\n\n.job-card-location {\n    font-size: 13px;\n    color: var(--text-muted);\n}\n\n.job-card-status {\n    font-size: 12px;\n    padding: 2px 8px;\n    background: #ebf8ff;\n    color: #2b6cb0;\n    border-radius: 4px;\n}\n\n.home-jobs-more,\n.home-news-more {\n    text-align: center;\n}\n\n/* 新闻预览 */\n.home-news {\n    background: #fff;\n}\n\n.news-pre-list {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));\n    gap: 24px;\n    margin-bottom: 32px;\n}\n\n.news-pre-item {\n    display: flex;\n    gap: 16px;\n    padding: 20px;\n    border: 1px solid var(--border-light);\n    border-radius: var(--radius-md);\n    transition: box-shadow 0.2s;\n}\n\n.news-pre-item:hover {\n    box-shadow: var(--shadow-sm);\n}\n\n.news-pre-img {\n    width: 120px;\n    height: 90px;\n    border-radius: 6px;\n    overflow: hidden;\n    flex-shrink: 0;\n}\n\n.news-pre-img img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n}\n\n.news-pre-content {\n    flex: 1;\n    min-width: 0;\n}\n\n.news-pre-date {\n    font-size: 12px;\n    color: var(--text-muted);\n}\n\n.news-pre-title {\n    font-size: 15px;\n    font-weight: 600;\n    color: var(--text-primary);\n    margin: 4px 0;\n    line-height: 1.4;\n    display: -webkit-box;\n    -webkit-line-clamp: 1;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n}\n\n.news-pre-desc {\n    font-size: 13px;\n    color: var(--text-secondary);\n    margin: 0 0 6px;\n    line-height: 1.5;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n    overflow: hidden;\n}\n\n.news-pre-link {\n    font-size: 13px;\n    color: var(--primary-light);\n    font-weight: 500;\n}\n\n@media (max-width: 768px) {\n    .home-section {\n        padding: 40px 0;\n    }\n    .intro-cards {\n        flex-direction: column;\n        align-items: center;\n    }\n    .intro-card {\n        max-width: 100%;\n    }\n    .stats-row-num {\n        font-size: 28px;\n    }\n    .job-cards {\n        grid-template-columns: 1fr;\n    }\n    .news-pre-list {\n        grid-template-columns: 1fr;\n    }\n    .news-pre-item {\n        flex-direction: column;\n    }\n    .news-pre-img {\n        width: 100%;\n        height: 160px;\n    }\n}\n</style>\n"],"mappings":"AAqHA;EACAA,IAAA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}