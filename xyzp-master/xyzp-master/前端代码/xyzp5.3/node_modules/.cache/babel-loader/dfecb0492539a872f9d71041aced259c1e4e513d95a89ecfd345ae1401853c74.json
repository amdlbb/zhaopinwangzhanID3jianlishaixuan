{"ast":null,"code":"import Footer from '@/components/Footer';\nexport default {\n  name: \"ProductService\",\n  components: {\n    Footer\n  }\n};","map":{"version":3,"names":["Footer","name","components"],"sources":["src/pages/ProductService/index.vue"],"sourcesContent":["<template>\n  <div class=\"product-page\">\n    <!-- Hero 区 -->\n    <section class=\"product-hero\">\n      <div class=\"page-container\">\n        <h1 class=\"product-hero-title\">产品与服务</h1>\n        <p class=\"product-hero-desc\">基于决策树算法的智能招聘管理解决方案</p>\n      </div>\n    </section>\n\n    <!-- 核心产品 -->\n    <section class=\"product-section\">\n      <div class=\"page-container\">\n        <h2 class=\"section-title\">智能简历OA筛选系统</h2>\n        <p class=\"section-subtitle\">从海量简历中精准定位优秀人才</p>\n\n        <div class=\"product-cards\">\n          <div class=\"product-card card\">\n            <div class=\"product-card-icon\">\n              <img src=\"https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=120&q=80\" alt=\"智能筛选图标图片\">\n            </div>\n            <h3 class=\"product-card-title\">智能简历筛选</h3>\n            <p class=\"product-card-desc\">基于ID3决策树算法，对学历、工作经验、技能匹配度等关键特征进行信息增益计算，自动判定简历匹配度。通过的简历优先展示，大幅缩短HR初筛时间。</p>\n          </div>\n\n          <div class=\"product-card card\">\n            <div class=\"product-card-icon\">\n              <img src=\"https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=120&q=80\" alt=\"招聘管理图标图片\">\n            </div>\n            <h3 class=\"product-card-title\">招聘流程管理</h3>\n            <p class=\"product-card-desc\">覆盖从职位发布、简历收集、面试安排到录取入职的全流程管理。支持部门独立管理招聘，管理员统一审核，流程清晰可控。</p>\n          </div>\n\n          <div class=\"product-card card\">\n            <div class=\"product-card-icon\">\n              <img src=\"https://images.unsplash.com/photo-1520607162513-77705c0f0dbf?w=120&q=80\" alt=\"面试管理图标图片\">\n            </div>\n            <h3 class=\"product-card-title\">面试管理系统</h3>\n            <p class=\"product-card-desc\">自动发送面试通知邮件，支持面试时间、地点管理。候选人状态实时跟进，从待面试到已录取全程可视化管理。</p>\n          </div>\n\n          <div class=\"product-card card\">\n            <div class=\"product-card-icon\">\n              <img src=\"https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=120&q=80\" alt=\"数据看板图标图片\">\n            </div>\n            <h3 class=\"product-card-title\">数据统计分析</h3>\n            <p class=\"product-card-desc\">提供多维度的数据看板，包括简历处理量、面试转化率、录取率等关键指标。用数据驱动招聘决策，持续优化招聘策略。</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- 技术优势 -->\n    <section class=\"tech-section\">\n      <div class=\"page-container\">\n        <h2 class=\"section-title\">技术优势</h2>\n        <p class=\"section-subtitle\">为什么选择基于决策树的智能筛选方案</p>\n\n        <div class=\"tech-grid\">\n          <div class=\"tech-item\">\n            <h4>可解释性强</h4>\n            <p>决策树的树形结构直观展示筛选规则，HR可清晰了解每份简历的判定依据，非技术背景也能轻松理解。</p>\n          </div>\n          <div class=\"tech-item\">\n            <h4>计算效率高</h4>\n            <p>ID3算法时间复杂度低，可在毫秒级完成上万份简历的分类预测，满足高并发场景需求。</p>\n          </div>\n          <div class=\"tech-item\">\n            <h4>客观公正</h4>\n            <p>基于信息增益的数学建模方式，消除人工筛选的主观偏见，确保每位候选人获得公平评估。</p>\n          </div>\n          <div class=\"tech-item\">\n            <h4>持续优化</h4>\n            <p>支持模型定期重训练，随着招聘数据积累，筛选准确率可以持续提升，实现自我迭代。</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <Footer></Footer>\n  </div>\n</template>\n\n<script>\nimport Footer from '@/components/Footer'\nexport default {\n  name: \"ProductService\",\n  components: {\n    Footer\n  }\n}\n</script>\n\n<style scoped>\n.product-hero {\n  background: linear-gradient(135deg, #0f2640 0%, #1a3a5c 50%, #2c5282 100%);\n  padding: 80px 0 60px;\n  text-align: center;\n}\n\n.product-hero-title {\n  font-size: 36px;\n  font-weight: 700;\n  color: #fff;\n  margin: 0 0 12px;\n}\n\n.product-hero-desc {\n  font-size: 18px;\n  color: #94a3b8;\n  margin: 0;\n}\n\n.product-section {\n  padding: 60px 0;\n  background: #fff;\n}\n\n.product-cards {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n  gap: 24px;\n}\n\n.product-card {\n  padding: 32px 24px;\n  text-align: center;\n  border: 1px solid var(--border-light);\n}\n\n.product-card-icon {\n  width: 60px;\n  height: 60px;\n  margin: 0 auto 16px;\n  border-radius: 12px;\n  overflow: hidden;\n}\n\n.product-card-icon img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.product-card-title {\n  font-size: 18px;\n  font-weight: 600;\n  color: var(--text-primary);\n  margin: 0 0 12px;\n}\n\n.product-card-desc {\n  font-size: 14px;\n  line-height: 1.7;\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n.tech-section {\n  padding: 60px 0;\n  background: var(--bg-light);\n}\n\n.tech-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));\n  gap: 24px;\n}\n\n.tech-item {\n  background: #fff;\n  padding: 28px;\n  border-radius: var(--radius-md);\n  box-shadow: var(--shadow-sm);\n  border-left: 4px solid var(--primary);\n}\n\n.tech-item h4 {\n  font-size: 17px;\n  font-weight: 600;\n  color: var(--text-primary);\n  margin: 0 0 8px;\n}\n\n.tech-item p {\n  font-size: 14px;\n  line-height: 1.7;\n  color: var(--text-secondary);\n  margin: 0;\n}\n\n@media (max-width: 768px) {\n  .product-hero {\n    padding: 60px 0 40px;\n  }\n  .product-hero-title {\n    font-size: 28px;\n  }\n  .product-hero-desc {\n    font-size: 16px;\n  }\n  .product-cards {\n    grid-template-columns: 1fr;\n  }\n  .tech-grid {\n    grid-template-columns: 1fr;\n  }\n}\n</style>\n"],"mappings":"AAoFA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,UAAA;IACAF;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}